<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="500.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg125673.ui.MainController"
      style="-fx-padding: 20px;">

    <Label text="Dungeon Arena RPG" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <!-- L'area di testo dove stamperemo cosa succede in battaglia -->
    <TextArea fx:id="logBattaglia" editable="false" prefHeight="300.0" prefWidth="550.0"
              style="-fx-font-size: 14px; -fx-control-inner-background: #000000; -fx-text-fill: #00FF00; -fx-font-family: 'Consolas';"/>

    <!-- Un contenitore orizzontale (HBox) per mettere i bottoni uno di fianco all'altro -->
    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="btnAttacca" text="⚔️ Attacca" onAction="#gestisciAttacco"
                style="-fx-font-size: 16px; -fx-base: #ff4d4d;"/>

        <Button fx:id="btnPozione" text="🧪 Usa Pozione" onAction="#gestisciPozione"
                style="-fx-font-size: 16px; -fx-base: #4da6ff;"/>
    </HBox>

</VBox>