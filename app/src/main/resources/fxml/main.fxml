<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="600.0" prefWidth="800.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg125673.ui.MainController"
      style="-fx-padding: 20px; -fx-background-color: #2b2b2b;">

    <Label text="Dungeon Arena RPG" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <!-- ZONA ALTA: Schermo diviso a metà -->
    <HBox alignment="CENTER" spacing="100.0">

        <!-- PARTE SINISTRA: Giocatore -->
        <VBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #3c3f41; -fx-padding: 15px; -fx-border-color: #4da6ff; -fx-border-width: 2px;">
            <Label fx:id="lblNomeGiocatore" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4da6ff;"/>
            <Label fx:id="lblHpGiocatore" style="-fx-font-size: 18px; -fx-text-fill: white;"/>
            <Label fx:id="lblArmaGiocatore" style="-fx-font-size: 14px; -fx-text-fill: yellow;"/>
            <Label text="--- Nello Zaino ---" style="-fx-font-size: 14px; -fx-text-fill: gray;"/>
            <Label fx:id="lblInventario" style="-fx-font-size: 14px; -fx-text-fill: white;"/>
        </VBox>

        <!-- PARTE DESTRA: Mostro -->
        <VBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-background-color: #3c3f41; -fx-padding: 15px; -fx-border-color: #ff4d4d; -fx-border-width: 2px;">
            <Label fx:id="lblNomeMostro" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ff4d4d;"/>
            <Label fx:id="lblHpMostro" style="-fx-font-size: 18px; -fx-text-fill: white;"/>
        </VBox>

    </HBox>

    <!-- ZONA CENTRALE: Bottoni -->
    <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10px;">
        <Button fx:id="btnAttacca" text=" Attacca" onAction="#gestisciAttacco" style="-fx-font-size: 16px; -fx-base: #ff4d4d;"/>
        <Button fx:id="btnPozione" text=" Usa Pozione" onAction="#gestisciPozione" style="-fx-font-size: 16px; -fx-base: #4da6ff;"/>
        <Button fx:id="btnEquipaggia" text=" Equipaggia Spada" onAction="#gestisciEquipaggia" style="-fx-font-size: 16px; -fx-base: #ffcc00;"/>
    </HBox>

    <!-- ZONA BASSA: Log Battaglia -->
    <TextArea fx:id="logBattaglia" editable="false" prefHeight="200.0" prefWidth="700.0"
              style="-fx-font-size: 14px; -fx-control-inner-background: #000000; -fx-text-fill: #00FF00; -fx-font-family: 'Consolas';"/>

</VBox>